{
  "servers": {
    "cypress": {
      "type": "http",
      "url": "https://mcp.cypress.io/mcp",
      "headers": {
        "Authorization": "Bearer ${input:CYPRESS_MCP_TOKEN}"
      }
    }
  },
  "inputs": [
    {
      "id": "CYPRESS_MCP_TOKEN",
      "type": "promptString",
      "description": "Enter your Cypress MCP personal access token",
      "password": true
    }
  ]
}